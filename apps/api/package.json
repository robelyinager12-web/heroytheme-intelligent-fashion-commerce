{
  "name": "@heroytheme/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema ../../database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../database/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx ../../database/prisma/seed.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "@prisma/client": "^5.20.0",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "redis": "^4.7.0",
    "cloudinary": "^2.5.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "prisma": "^5.20.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.7.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/morgan": "^1.9.0"
  }
}